# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# ─────────────────────────────────────────────
# Clerk
# https://dashboard.clerk.com
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Name of the JWT template created in Clerk that signs with the Supabase JWT secret
CLERK_SUPABASE_JWT_TEMPLATE=supabase

# ─────────────────────────────────────────────
# Supabase
# https://supabase.com/dashboard
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx
# Used to sign the Clerk JWT template so Supabase trusts it
SUPABASE_JWT_SECRET=xxx

# ─────────────────────────────────────────────
# Resend (transactional email)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Form Studio <hello@formstudio.com>

# ─────────────────────────────────────────────
# Stripe (Phase 2 — safe to leave blank in Phase 1)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────
# Super admin (bootstrap)
# Comma-separated Clerk user IDs with super admin access
# ─────────────────────────────────────────────
SUPER_ADMIN_CLERK_IDS=

# ─────────────────────────────────────────────
# Private beta gate
# Comma-separated "code:label" pairs. If set, every visitor must enter
# one of these codes at /beta before anything else loads. Leave empty
# to open the app to the public.
# Example: trainer-joelle:Joelle,friend-rand:Rand
# ─────────────────────────────────────────────
BETA_CODES=
